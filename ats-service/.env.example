# Get a FREE Groq API key at https://console.groq.com
# Used for Llama-3-8B "Critical Improvements" generation
# If not set, the service falls back to rule-based feedback (scoring still works)
GROQ_API_KEY=your_groq_api_key_here

# ChromaDB persistence directory (defaults to ./chroma_db if not set)
CHROMA_DB_PATH=./chroma_db

# Host & Port (defaults below)
HOST=0.0.0.0
PORT=8000
